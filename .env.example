# Application environment: dev | prod
APP_ENV=dev

# Django
DEBUG=True
SECRET_KEY=change-this-secret-key
APP_VERSION=1.0.5
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
DJANGO_SETTINGS_MODULE=config.settings_dev

# Database
DB_NAME=lineops
DB_USER=lineops
DB_PASSWORD=lineops
DB_HOST=db
DB_PORT=5432
DB_TEST_NAME=
USE_SQLITE_TEST_DB=True

# Optional (production)
SECURE_SSL_REDIRECT=True
CSRF_TRUSTED_ORIGINS=https://seu-dominio.com
USE_X_FORWARDED_PROTO=False
HEALTHCHECK_REQUIRE_AUTH=False
WHATSAPP_MEOW_WEBHOOK_TOKEN=
WHATSAPP_MEOW_OWNER_CHECK_TOKEN=
