SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Health check das instancias Meow a cada 5 minutos.
*/5 * * * * cd /opt/lineops/lineops && ./scripts/run_qa_manage_command.sh check_meow_health >> /opt/lineops/lineops/logs/ops/check_meow_health.log 2>&1

# Capacidade por instancia a cada 15 minutos.
*/15 * * * * cd /opt/lineops/lineops && ./scripts/run_qa_manage_command.sh check_meow_capacity >> /opt/lineops/lineops/logs/ops/check_meow_capacity.log 2>&1

# Sincronizacao de status das sessoes a cada 10 minutos.
*/10 * * * * cd /opt/lineops/lineops && ./scripts/run_qa_manage_command.sh sync_whatsapp_sessions >> /opt/lineops/lineops/logs/ops/sync_whatsapp_sessions.log 2>&1

# Reconcilia inconsistencias locais uma vez por hora.
0 * * * * cd /opt/lineops/lineops && ./scripts/run_qa_manage_command.sh reconcile_whatsapp_sessions >> /opt/lineops/lineops/logs/ops/reconcile_whatsapp_sessions.log 2>&1
