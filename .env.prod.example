# Application environment
APP_ENV=prod

# Django
DEBUG=False
SECRET_KEY=change-this-production-secret-key
DJANGO_SETTINGS_MODULE=config.settings_prod

ALLOWED_HOSTS=srvqa-01,10.103.4.184,localhost,srvqa-01.globalcobranca.com.br,127.0.0.1,lineops.somosglobal.com.br
CSRF_TRUSTED_ORIGINS=https://srvqa-01,https://10.103.4.184,https://localhost,https://srvqa-01.globalcobranca.com.br,https://lineops.somosglobal.com.br
SECURE_SSL_REDIRECT=True
USE_X_FORWARDED_PROTO=True
HEALTHCHECK_REQUIRE_AUTH=False

# Database
DB_NAME=lineops
DB_USER=lineops
DB_PASSWORD=lineops
DB_HOST=db
DB_PORT=5432

# TLS mounted on nginx container
TLS_CERT_PATH=/opt/app/src/lineops/certs/lineops-fullchain.pem
TLS_KEY_PATH=/opt/app/src/lineops/certs/lineops-privkey.pem

# Reconexao WhatsApp via RPA (MongoDB)
# Habilita o fluxo de reconexao na interface web
RECONNECT_ENABLED=True
# URI de conexao com o MongoDB do RPA
RECONNECT_MONGO_URI=mongodb://admin:pa25diw9OY16%5Dq%3Ak@10.103.4.111:27017/admin?directConnection=true&serverSelectionTimeoutMS=2000&appName=mongosh
# Database e collection usados pelo RPA (nao alterar sem alinhar com o time RPA)
RECONNECT_MONGO_DATABASE=RPA
RECONNECT_MONGO_COLLECTION=reconnect_sessions
# Intervalo de polling do status no frontend (ms)
RECONNECT_POLL_INTERVAL_MS=1000
# Mapeamento de PhoneLine.origem para o target_server esperado pelo RPA
# Os valores do lado direito devem bater com OrchestratorConfig.SERVER_ALIAS_MAP no RPA
RECONNECT_TARGET_SERVER_MAP={"SRVMEMU-01":"srvmemu01","SRVMEMU-02":"srvmemu02","SRVMEMU-03":"srvmemu03","SRVMEMU-04":"srvmemu04","SRVMEMU-05":"srvmemu05","SRVMEMU-06":"srvmemu06"}
# ATENCAO: antes de habilitar, criar o indice unico parcial no MongoDB:
# db.reconnect_sessions.createIndex({phone_number:1},{unique:true,partialFilterExpression:{active_lock:true}})
# Ou usar: python manage.py create_reconnect_indexes
